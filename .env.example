# Federated RAG — Phase 5 Environment Configuration
# Copy this file to .env and fill in your values

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama" = local, private (DEFAULT). "deepseek" = cloud API (privacy risk).
# WARNING: Secure-scope queries are BLOCKED from using DeepSeek.
LLM_PROVIDER=ollama

# ── Ollama (used when LLM_PROVIDER=ollama) ────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# Two-tier model configuration (Phase 5):
#   Fast tier — extraction, summarization, query decomposition, per-theme synthesis
#   Reasoning tier — cross-theme synthesis, gap analysis, critique, arbitration
#   Alt fast tier — second per-theme model for dual-model parallelism
#
# Memory: gemma4:e4b (~9.6GB) + medgemma:4b (~3.3GB) = ~12.9GB for fast tier
#   + qwen3.6:35b (~23GB) for reasoning = ~36GB peak (tight but fits with
#   OLLAMA_KEEP_ALIVE=60s allowing fast models to unload before qwen loads)
#
# Dual-model parallelism: themes are split across two different models,
# enabling true GPU parallelism (different weights = independent GPU streams).
# gemma4:e4b handles half the themes, medgemma:4b handles the other half.
OLLAMA_SMALL_MODEL=gemma4:e4b
OLLAMA_ALT_MODEL=medgemma:4b
OLLAMA_LARGE_MODEL=qwen3.6:35b

# Keep models loaded for 60s after last request. Shorter value helps the
# fast-tier model unload before the reasoning tier loads, reducing peak memory.
# Set to 300s (5 min) on machines with 48GB+.
OLLAMA_KEEP_ALIVE=60s

# LLM request timeout in seconds.  Local Ollama may need higher values
# (300-600s) because generation is slower than cloud APIs.
LLM_TIMEOUT=900

# Maximum output tokens per LLM call.  4096 is sufficient for synthesis,
# critique, and arbitration tasks (typically 500-2000 tokens output).
# Lower values = faster generation.  Set higher for cross-theme synthesis.
LLM_MAX_TOKENS=4096

# ── Ollama Server Parallelism ──────────────────────────────────────────────
# These are server-side env vars.  Set them in your shell BEFORE starting
# Ollama, or configure via launchctl for the macOS app:
#
#   launchctl setenv OLLAMA_NUM_PARALLEL 4
#   launchctl setenv OLLAMA_MAX_QUEUE 8
#   # Then quit and reopen the Ollama app
#
# OLLAMA_NUM_PARALLEL (default 1): max concurrent batches on GPU.
#   Recommended: 4 for 36GB M3 Max (each parallel request uses ~0.5-2GB KV cache).
# OLLAMA_MAX_QUEUE (default 512): max requests queued before rejecting.

# ── DeepSeek (used when LLM_PROVIDER=deepseek) ────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# ── Zotero Integration (optional) ─────────────────────────────────────────────
ZOTERO_LIBRARY_ID=
ZOTERO_API_KEY=

# ── Corpus & Project Directories ──────────────────────────────────────────────
PUBLIC_CORPUS_DIR=./papers/public
SECURE_CORPUS_DIR=./papers/secure
PROJECT_DIR=projects/default

# ── Security ──────────────────────────────────────────────────────────────────
SECURITY_AUDIT_LOG=./logs/security_audit.log
BOUNDARY_SCRUB_PATTERNS=./config/scrub_patterns.txt
